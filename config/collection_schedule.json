{
  "_comment": "Askloud Collection Schedule — defines what to collect and how often.",
  "_format": {
    "name":           "Human-readable label shown in scheduler output",
    "provider":       "aws | azure | gcp",
    "args":           "CLI args without the binary name or --output flag",
    "file_path":      "Destination under data/ (profile is auto-injected for AWS)",
    "interval_hours": "Re-collect when the file is older than this many hours (decimals OK, e.g. 0.5)"
  },

  "resources": [
    {
      "name":           "EC2 — DevelopmentCampaign / us-east-1",
      "provider":       "aws",
      "args":           ["ec2", "describe-instances", "--region", "us-east-1"],
      "file_path":      "data/aws/DevelopmentCampaign/us-east-1/ec2.json",
      "interval_hours": 1
    },
    {
      "name":           "EC2 — DevelopmentCampaign / ap-southeast-1",
      "provider":       "aws",
      "args":           ["ec2", "describe-instances", "--region", "ap-southeast-1"],
      "file_path":      "data/aws/DevelopmentCampaign/ap-southeast-1/ec2.json",
      "interval_hours": 1
    },
    {
      "name":           "EBS — Production / us-east-1",
      "provider":       "aws",
      "args":           ["ec2", "describe-volumes", "--region", "us-east-1"],
      "file_path":      "data/aws/Production/us-east-1/ebs.json",
      "interval_hours": 1
    },
    {
      "name":           "EBS — Production / eu-central-1",
      "provider":       "aws",
      "args":           ["ec2", "describe-volumes", "--region", "eu-central-1"],
      "file_path":      "data/aws/Production/eu-central-1/ebs.json",
      "interval_hours": 1
    },
    {
      "name":           "EC2 — Production / us-east-1",
      "provider":       "aws",
      "args":           ["ec2", "describe-instances", "--region", "us-east-1"],
      "file_path":      "data/aws/Production/us-east-1/ec2.json",
      "interval_hours": 1
    },
    {
      "name":           "VPC — NetworkServices / us-east-1",
      "provider":       "aws",
      "args":           ["ec2", "describe-vpcs", "--region", "us-east-1"],
      "file_path":      "data/aws/NetworkServices/us-east-1/vpc.json",
      "interval_hours": 1
    },
    {
      "name":           "EKS — SharedQA / us-east-1",
      "provider":       "aws",
      "args":           ["eks", "list-clusters", "--region", "us-east-1"],
      "file_path":      "data/aws/SharedQA/us-east-1/eks.json",
      "interval_hours": 1
    },
    {
      "name":           "Azure VMs",
      "provider":       "azure",
      "args":           ["vm", "list"],
      "file_path":      "data/azure/vm.json",
      "interval_hours": 1
    },
    {
      "name":           "GCP Compute Instances",
      "provider":       "gcp",
      "args":           ["compute", "instances", "list"],
      "file_path":      "data/gcp/vm.json",
      "interval_hours": 1
    }
  ]
}
