# Copy this file to _secret_vars.tf and fill in values.
# _secret_vars.tf is .gitignored — never commit actual secrets.
#
# Kubernetes secrets (ANTHROPIC_API_KEY, DJANGO_SECRET_KEY) are NOT managed
# here — they are created by deploy-eks.sh from environment variables at
# deploy time to keep them out of Terraform state.
#
# Add variables here only if Terraform itself needs a secret value (e.g. an
# external provider API key).

# Example:
# variable "some_api_key" {
#   description = "API key for an external provider used by Terraform"
#   type        = string
#   sensitive   = true
# }
